programa {
  funcao inicio() {
    
    
    real velocidade //declarando variável
  
  
  //programa semáfaro
    escreva("qual a velocidade atual do carro? ")
    leia (velocidade)

    //escreva condicional
    se (velocidade > 100){
    escreva("multado por ultrapassasr a rua á 80km/h")
    }senao{
     escreva("velocidade permitida cuidado") 
    }
    escreva("/n")//quebra uma linha
    

  } 
  
}
